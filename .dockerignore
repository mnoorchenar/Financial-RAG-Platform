# Exclude ONLY the private config — example template must reach the image
config.py
# Never exclude config.example.py — the Dockerfile copies it to config.py at build time

# Exclude large generated data (rebuilt at image build time by ingest.py)
data/faiss_index/
data/uploads/

# Python cache
__pycache__/
*.pyc
*.pyo

# Dev tools
.git/
.gitignore
.vscode/
.idea/
*.md
notebooks/
tests/